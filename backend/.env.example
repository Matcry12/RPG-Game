# Copy to backend/.env and fill in. Never commit the real .env (gitignored).

# Groq free tier — primary NPC brain. Get a key at https://console.groq.com/keys
GROQ_API_KEY=

# Optional: local failover brain (Ollama). Defaults work if Ollama runs on localhost.
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=gemma3n:e2b

# Feature flags (ablation eval toggles these). Defaults shown.
# GROUNDING_GATE=true
# MEMORY_STREAM=true
# REFLECTION=true

# LangSmith tracing — set these to see every LLM prompt/response in the UI.
# Get a free key at https://smith.langchain.com → Settings → API Keys.
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=rpg-npc
