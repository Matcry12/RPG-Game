# Copy to backend/.env and fill in. Never commit the real .env (gitignored).

# LLM provider order: "kira" or "groq" — the other becomes the automatic fallback.
# LLM_PRIMARY=kira

# Kira AI (OpenAI-compatible, free tier: kira-mini-1.0)
KIRA_API_KEY=

# Groq (free tier: llama-3.3-70b-versatile)
GROQ_API_KEY=

# Optional: local failover brain (Ollama). Defaults work if Ollama runs on localhost.
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=gemma3n:e2b

# Feature flags (ablation eval toggles these). Defaults shown.
# GROUNDING_GATE=true
# MEMORY_STREAM=true
# REFLECTION=true

# Lore retrieval mode (ADR-0015). "naive" = raw query, 0 extra LLM calls (default).
# "mix" = history-aware query rewrite + entity graph; resolves vague refs ("who is he?")
# at the cost of one ~0.5-1s extraction LLM call per lore turn.
# LORE_QUERY_MODE=naive

# LangSmith tracing — set these to see every LLM prompt/response in the UI.
# Get a free key at https://smith.langchain.com → Settings → API Keys.
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=rpg-npc
