# ── Secrets / env ───────────────────────────────────────────────
# GROQ_API_KEY and any local config live here — never commit.
.env
.env.*
!.env.example

# ── Python (backend/) ───────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.installed.cfg
*.egg

# Virtual envs
.venv/
venv/
env/
ENV/

# Tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/

# ── Project runtime artifacts (the LLM-never-owns-truth state) ──
# SQLite authoritative state + LangGraph checkpointer DBs
*.db
*.sqlite
*.sqlite3
*.db-journal
*.db-wal
*.db-shm
# ChromaDB persistence
chroma/
.chroma/
backend/data/chroma/
# LightRAG lore graph (runtime artifact, seeded via /world/seed)
backend/data/lightrag/
# Generated lore artifacts (source lore is committed in shared/lore/)
backend/data/lorebook.embedded.json

# ── Godot (game/) ───────────────────────────────────────────────
# Godot 4 import cache + temp
game/.godot/
game/.import/
game/export.cfg
game/export_presets.cfg
# Mono/C# (if used later)
game/.mono/
game/data_*/

# ── Editors / OS ────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*~
.DS_Store
Thumbs.db

# ── Local-only eval overrides (use claude -p / free tooling, not for public repo) ──
backend/eval/*_local.py
backend/eval/ablation_results.json

# ── OMC / harness scratch (keep durable docs, drop ephemera) ────
.omc/logs/
.omc/state/
.omc/notepad.md
.omx/
